{
	"info": {
		"_postman_id": "go-api-practice-7",
		"name": "Go API Practice 7 - 圖書館書籍與借閱",
		"description": "書籍 (books) 與借閱 (borrowals)。GET 不需 token；POST 需 Authorization: Bearer {{token}}。書籍支援 ?available=true|false。",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8082" },
		{ "key": "token", "value": "demo-token-123" },
		{ "key": "bookId", "value": "1" },
		{ "key": "borrowalId", "value": "1" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "GET /api/me (帶 token)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/me"
					}
				}
			]
		},
		{
			"name": "書籍 (books)",
			"item": [
				{ "name": "取得所有書籍", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/books" } },
				{ "name": "取得可借閱書籍", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/books?available=true" } },
				{ "name": "取得單一書籍", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/books/{{bookId}}" } },
				{
					"name": "新增書籍",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"title\": \"RESTful API 設計\",\n  \"isbn\": \"978-986-123456-3\"\n}" },
						"url": "{{baseUrl}}/api/books"
					}
				},
				{
					"name": "更新書籍",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"title\": \"Go 程式設計（第二版）\",\n  \"isbn\": \"978-986-123456-0\"\n}" },
						"url": "{{baseUrl}}/api/books/{{bookId}}"
					}
				},
				{
					"name": "刪除書籍",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/books/{{bookId}}"
					}
				}
			]
		},
		{
			"name": "借閱 (borrowals)",
			"item": [
				{ "name": "取得所有借閱紀錄", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/borrowals" } },
				{ "name": "取得單一借閱", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/borrowals/{{borrowalId}}" } },
				{
					"name": "借書",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"book_id\": 1,\n  \"user_name\": \"小明\"\n}" },
						"url": "{{baseUrl}}/api/borrowals"
					}
				},
				{
					"name": "還書",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/borrowals/{{borrowalId}}/return"
					}
				}
			]
		}
	]
}
